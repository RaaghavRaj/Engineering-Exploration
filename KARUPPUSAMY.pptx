------MultipartBoundary--XjVThJqUtoXrBy1krrC7FCPPNQsR8mrvLEVFMbUHFS----
Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: https://res.public.onecdn.static.microsoft/officeonline/pods/s/162031240575_PptScripts//mobileappv2/pptmweb/PPTMobileApp.css

@charset "utf-8";

.js-focus-visible { scrollbar-gutter: unset; }

.mobile-app-class { margin: 0px; width: 100%; background-color: rgb(248, 248, 248); overflow: hidden; font-family: "Segoe UI", "Segoe UI Web", sans-serif; scrollbar-color: rgb(139, 139, 139) transparent; }

.hide-mobileApp-View { display: none !important; }

.loading-page-container-class { width: 100%; height: 100%; display: none; }

.error-page-container-class { width: 100%; height: 100%; display: none; }

.error-div-dialog-overlay { position: absolute; z-index: 999999; width: 100%; background-color: rgb(248, 248, 248); height: calc(-70px + 100vh); padding-top: 70px; text-align: center; overflow-y: auto; top: 0px; }

.error-image-div-class { text-align: center; }

.errorpage_bottomBase-class { display: none; position: absolute; top: 320px; margin-left: 30px; margin-right: 30px; left: 0px; width: 100%; background: rgb(198, 198, 198); opacity: 0.5; }

.error-try-again-button { background-color: rgb(185, 73, 44); color: white; padding: 5px 8px 7px; border-width: medium; border-color: currentcolor; border-image: none; border-style: none; outline: none; border-radius: 2px; font-family: "Segoe UI", "Segoe UI Web", sans-serif; font-size: 14px; }

.error-trackingId { font-size: 8px; }

.error-dummy-div { padding: 8px; }

.copy-text { user-select: all; }

.thumbnail-page-container-class { margin: 0px; width: 100%; position: inherit; display: grid; grid-template-columns: auto; overscroll-behavior: contain; }

.thumbnail-page-containerDW-class { position: absolute; }

.thumbNail-grid-list-view-class { position: absolute; width: 100%; }

.fallback-list-view-class { position: absolute; bottom: 0px; top: 0px; width: 100%; }

.thumbNail-grid-list-view-class.thumbNailWithHeaderV2-class { top: 0px; }

.FallbackViewWithHeaderV2 { top: 0px; }

.single-slide-page-main-body { position: relative; top: 1px; }

.single-slide-page-main-body-slider { overflow: hidden auto; height: calc(-65px + 100vh); touch-action: auto; }

.comments-enabled-class.thumbNail-grid-list-view-class { position: relative; width: 100%; height: calc(-70px + 100vh); background-color: rgb(248, 248, 248); }

.section-list-view-visible-class { overflow-y: auto; position: relative; height: 100%; padding: 0px; scrollbar-width: none; }

.section-list-view-visible-class-iphone, .section-list-view-visible-class-iphone-slr { position: relative; }

.section-list-view-visible-class::-webkit-scrollbar { display: none; }

.generic-view-class { outline: none; width: 100% !important; height: 100% !important; }

.generic-view-class .drag-over-frame-view-hidden-class { height: 0px !important; width: 0px !important; }

.generic-view-class * { outline: none; }

.section-view-visible-class { font-family: "Segoe UI semibold"; font-size: 14px; color: rgb(168, 168, 168); text-align: left; padding-right: 8px; padding-left: 8px; top: 10px; }

.error-info-bar-class { margin: 0px; width: 100%; position: inherit; }

.rtl-class .section-view-visible-class { text-align: right; }

.rtl-class.section-list-view-visible-class { direction: rtl; }

.grid-list-view-visible-class { display: flex; width: 100%; flex-flow: wrap; justify-content: center; }

.grid-frame-view-visible-class { position: relative; -webkit-tap-highlight-color: transparent; }

.comments-enabled-class.grid-frame-view-visible-class { display: grid; position: relative; width: 100%; padding: 16px 0px 0px; }

.v2HeaderAdjustmentForSlideGrid-class { padding: 4px 0px 0px; }

.grid-frame-view-inner-container-class { width: 100%; }

.grid-frame-view-slide-info-container-class { position: relative; display: flex; grid-row: 2; bottom: 0px; height: 18px; width: 100%; color: rgb(255, 255, 255); background: rgb(248, 248, 248); padding-top: 2px; }

.grid-frame-view-slide-index-container-class { bottom: 30px; padding: 0px 5px; font-size: 14px; color: rgb(168, 168, 168); margin-bottom: -27px; top: 0px; position: relative !important; }

#loading-page-container-v2 .grid-frame-view-slide-index-container-class { display: none !important; }

.comments-enabled-class.grid-frame-view-slide-index-container-class { position: absolute; bottom: 8px; padding: 0px 4px; font-size: 10px; color: rgb(78, 77, 77); }

.grid-frame-view-num-comments-container-class { position: absolute; display: block; bottom: 12px; right: 15px; padding: 0px 5px; font-size: 10px; color: rgb(116, 113, 113); }

.rtl-class .grid-frame-view-slide-index-container-class { right: 30px; }

.grid-content-view-visible-class { width: 247px; height: 140px; outline: rgb(210, 210, 206) solid 0px; }

.comments-enabled-class.grid-content-view-visible-class { width: 950px; height: 140px; outline: rgb(210, 210, 206) solid 0px; grid-row: 1; position: relative; }

.grid-frame-view-visible-class:hover .grid-content-view-visible-class { outline: rgb(179, 176, 173) solid 0px; }

@media (hover: hover) and (pointer: fine) {
  .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class img { outline: rgba(196, 62, 28, 0.75) solid 3px; outline-offset: -1.5px; box-shadow: rgba(0, 0, 0, 0.14) 0px 0px 3px, rgba(0, 0, 0, 0.2) 0px 3px 3px; }
  #loading-page-container-v2 .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class, .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class:has(img[src="https://cdn.hubblecontent.osi.office.net/m365content/publish/97e03db7-9ecb-4058-881d-b859e4f852b2/image.png"]) { outline: rgba(196, 62, 28, 0.75) solid 3px; outline-offset: -1.5px; }
}

@media (hover: none) and (pointer: coarse) {
  .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class img { outline: none; }
  #loading-page-container-v2 .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class, .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class:has(img[src="https://cdn.hubblecontent.osi.office.net/m365content/publish/97e03db7-9ecb-4058-881d-b859e4f852b2/image.png"]) { outline: none; }
}

#loading-page-container-v2 .grid-frame-view-visible-class .grid-content-view-visible-class .content-image-view-visible-class, .grid-frame-view-visible-class .grid-content-view-visible-class .content-image-view-visible-class:has(img[src="https://cdn.hubblecontent.osi.office.net/m365content/publish/97e03db7-9ecb-4058-881d-b859e4f852b2/image.png"]) { box-shadow: rgba(0, 0, 0, 0.14) 0px 0px 3px, rgba(0, 0, 0, 0.2) 0px 3px 3px; }

#loading-page-container-v2 .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class img, .grid-frame-view-visible-class:hover .grid-content-view-visible-class .content-image-view-visible-class img[src="https://cdn.hubblecontent.osi.office.net/m365content/publish/97e03db7-9ecb-4058-881d-b859e4f852b2/image.png"] { outline: none; }

.grid-content-view-visible-class:hover { cursor: pointer; }

.content-image-view-visible-class { display: flex; line-height: 0; width: 100%; height: 100%; justify-content: center; align-items: center; min-height: 150px; background-color: rgb(255, 255, 255); }

.content-image-view-hidden-class { display: none; }

.content-image-view-visible-class img { width: 100%; height: 99%; box-shadow: rgba(0, 0, 0, 0.14) 0px 0px 2px, rgba(0, 0, 0, 0.2) 0px 2px 2px; }

.content-image-view-visible-class img[src="https://cdn.hubblecontent.osi.office.net/m365content/publish/97e03db7-9ecb-4058-881d-b859e4f852b2/image.png"] { mask-image: linear-gradient(90deg, black 0%, black 25%, transparent 50%, black 75%, black 100%); mask-size: 300% 100%; mask-position: -300% 0%; animation: 6s linear 0s infinite normal none running shimmer; aspect-ratio: 1.78 / 1; box-sizing: border-box; }

@keyframes shimmer { 
  0% { mask-position: 300% 0%; }
  100% { mask-position: -300% 0%; }
}

.container-rendered-as-grid-class.grid-content-view-visible-class { outline: none; }

.grid-frame-view-visible-class.grid-frame-view-selected-class .grid-content-view-visible-class { outline: rgb(232, 110, 88) solid 0px; }

.grid-frame-view-visible-class.grid-frame-view-selected-class .grid-content-view-visible-class .content-image-view-visible-class img { outline: rgba(196, 62, 28, 0.75) solid 3px; outline-offset: -1.5px; box-shadow: rgba(0, 0, 0, 0.14) 0px 0px 3px, rgba(0, 0, 0, 0.2) 0px 3px 3px; }

.grid-frame-view-visible-class.grid-frame-view-selected-class:hover .grid-content-view-visible-class { outline: rgb(232, 110, 88) solid 0px; }

.grid-frame-view-visible-class.grid-frame-view-selected-class .grid-frame-view-slide-index-container-class { color: rgb(85, 85, 85); font-size: 12px; font-family: "Segoe UI semibold"; }

.grid-frame-view-visible-class.grid-frame-view-active-focus-class .grid-content-view-visible-class { outline: none; }

.grid-frame-view-visible-class.grid-frame-view-hidden-slide-class .grid-content-view-visible-class .content-image-view-visible-class { opacity: 0.5; }

.grid-frame-view-visible-class.grid-frame-view-hidden-slide-class .grid-frame-view-slide-index-container-class::after { border-bottom: 1px solid; transform: rotate(20deg); content: ""; width: 90%; position: absolute; top: 8px; left: 1px; }

.single-slide-class, .slide-show-class-portrait { position: absolute; width: 100%; height: 100%; margin: 0px; background-color: rgb(248, 248, 248); overscroll-behavior: contain; }

.single-slide-class { position: relative; top: 3px; }

.slide-show-class-landscape { height: 100%; }

.slide-show-background-color-class { background-color: black; }

